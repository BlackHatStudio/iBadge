# Express API
PORT=4000
JWT_SECRET=BadgeThisKey

# SQL Server (localhost — use with `mssql` package)
# Named instance (e.g. SQLEXPRESS): set host to localhost\SQLEXPRESS and use the instance port from SQL Server Configuration Manager.
SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=YourStrong@Passw0rd
SQLSERVER_DATABASE=ibadge

# TLS for local dev: set encrypt=false OR trust the server cert (common on dev machines)
SQLSERVER_ENCRYPT=false
SQLSERVER_TRUST_SERVER_CERTIFICATE=true



# Database
DB_SERVER=localhost
DB_PORT=1433
DB_INSTANCE=
DB_NAME=iBadge
DB_USER=ibadge
DB_PASSWORD=BadgeThis
DB_ENCRYPT=true
DB_TRUST_SERVER_CERT=true
DB_AUTH=sql
