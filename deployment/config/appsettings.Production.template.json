{
  "server": {
    "host": "127.0.0.1",
    "port": __API_PORT__,
    "trustedProxy": false,
    "version": "__APP_VERSION__"
  },
  "database": {
    "kioskConnectionString": "__KIOSK_DB_CONNECTION_STRING__",
    "accessControlConnectionString": "__SOURCE_DB_CONNECTION_STRING__"
  },
  "security": {
    "adminPinHash": "__ADMIN_PIN_HASH__",
    "jwtSecret": "__JWT_SECRET__"
  },
  "exports": {
    "rootPath": "__EXPORT_ROOT__"
  },
  "logging": {
    "rootPath": "__LOG_ROOT__"
  },
  "rules": {
    "duplicateWindowSeconds": __DUPLICATE_WINDOW_SERVER_SECONDS__
  },
  "imports": {
    "intervalHours": __IMPORT_INTERVAL_HOURS__
  }
}
